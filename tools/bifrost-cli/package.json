{
  "name": "@bifrost/cli",
  "version": "1.0.0",
  "description": "Bifrost CLI — Feature orchestration infrastructure for AI agents",
  "keywords": [
    "bifrost",
    "cli",
    "ai",
    "agents",
    "wiboo"
  ],
  "homepage": "https://github.com/bifrost-framework",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bifrost": "./bin/run.js"
  },
  "oclif": {
    "bin": "bifrost",
    "dirname": "bifrost",
    "commands": "./dist/commands",
    "plugins": [],
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc --watch -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepack": "npm run clean && npm run build",
    "package": "npm run build && npx pkg . --output bin/bifrost"
  },
  "dependencies": {
    "@oclif/core": "^3.27.0",
    "chalk": "^4.1.2",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "ora": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin",
    "dist",
    "npm-shrinkwrap.json",
    "oclif.manifest.json"
  ]
}
