{
  "_doc": {
    "purpose": "Maps {{injection-point}} keys to their value sources for bifrost-init hydration."
  },
  "_artifact_templates": {
    "STATE.md": {
      "id": { "source": "computed", "value": "uuid" },
      "project-name": { "source": "interview", "key": "project-name" },
      "status": { "source": "computed", "value": "constant:pending" },
      "created": { "source": "computed", "value": "iso-timestamp" },
      "version": { "source": "computed", "value": "framework-version" },
      "token-budget": { "source": "computed", "value": "constant:500000" }
    },
    "PATIENT.md": {
      "project-name": { "source": "interview", "key": "project-name" },
      "target-app": { "source": "interview", "key": "target-app" },
      "author-name": { "source": "interview", "key": "author-name" },
      "date": { "source": "computed", "value": "iso-date" }
    },
    "TRAJECTORY.md": {
      "feature-id": { "source": "computed", "value": "kebab-case-of-project-name" },
      "project-name": { "source": "interview", "key": "project-name" },
      "target-app": { "source": "interview", "key": "target-app" }
    }
  },
  "_agent_templates": {
    "Intake_Template.md": {
      "project-name": { "source": "interview", "key": "project-name" },
      "target-app": { "source": "interview", "key": "target-app" },
      "tech-stack": { "source": "knowledge", "file": "TECH_STACK.md" },
      "manual-core": { "source": "knowledge", "file": "FRONTEND_REPOSITORY_MANUAL.md", "sections": ["1", "2"] },
      "api-contracts": { "source": "knowledge", "file": "API_CONTRACTS.md" },
      "component-library": { "source": "knowledge", "file": "COMPONENT_LIBRARY.md" }
    },
    "CodeGen_Template.md": {
      "manual-patterns": { "source": "knowledge", "file": "FRONTEND_REPOSITORY_MANUAL.md", "sections": ["2", "7", "13"] },
      "testing-rules": { "source": "knowledge", "file": "FRONTEND_REPOSITORY_MANUAL.md", "sections": ["15"] },
      "api-contracts": { "source": "knowledge", "file": "API_CONTRACTS.md" },
      "component-library": { "source": "knowledge", "file": "COMPONENT_LIBRARY.md" }
    }
  }
}
