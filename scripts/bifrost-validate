#!/usr/bin/env node

/**
 * Bifrost Validator
 * Used in CI/CD pipelines to enforce framework standards
 */

const fs = require('fs');
const path = require('path');
const sm = require('../runtime/state-manager.js');

const args = process.argv.slice(2);
const command = args[0];
const target = args[1];

if (!command) {
    console.log('Uso: bifrost-validate <state|plan|api-calls|standards|qa-report|merge-ready> [caminho]');
    process.exit(1);
}

const REPO_ROOT = path.resolve(__dirname, '..');

switch (command) {
    case 'state':
        validateState(target || '.bifrost/STATE.md');
        break;
    case 'plan':
        validatePlan(target || '.bifrost/PLAN.md');
        break;
    case 'api-calls':
        validateApiCalls();
        break;
    case 'standards':
        validateStandards();
        break;
    case 'qa-report':
        validateQaReport(target || '.bifrost/QA_REPORT.md');
        break;
    case 'merge-ready':
        validateMergeReady();
        break;
    default:
        console.error(`Comando de validação desconhecido: ${command}`);
        process.exit(1);
}

function validateState(filePath) {
    console.log(`[INFO] Validando estado: ${filePath}`);
    try {
        const state = sm.loadState(path.resolve(process.cwd(), filePath));
        console.log('[OK] Estado é válido.');
        console.log(`   Funcionalidade: ${state.feature}`);
        console.log(`   Status: ${state.status}`);
    } catch (err) {
        console.error(`[ERRO] Validação de estado falhou: ${err.message}`);
        process.exit(1);
    }
}

function validatePlan(filePath) {
    console.log(`[INFO] Validando plano: ${filePath}`);
    const fullPath = path.resolve(process.cwd(), filePath);
    if (!fs.existsSync(fullPath)) {
        console.error('[ERRO] PLAN.md não encontrado.');
        process.exit(1);
    }
    // Basic markdown validation
    const content = fs.readFileSync(fullPath, 'utf8');
    if (!content.includes('# PLAN') && !content.includes('## Task')) {
        console.error('[ERRO] Formato do PLAN.md inválido. Deve conter tarefas.');
        process.exit(1);
    }
    console.log('[OK] Plano é válido.');
}

function validateQaReport(filePath) {
    console.log(`[INFO] Validando relatório de QA: ${filePath}`);
    const fullPath = path.resolve(process.cwd(), filePath);
    if (!fs.existsSync(fullPath)) {
        console.error('[ERRO] QA_REPORT.md não encontrado.');
        process.exit(1);
    }
    const content = fs.readFileSync(fullPath, 'utf8');
    if (content.includes('FAIL') || content.includes('FAILED')) {
        console.error('[ERRO] Relatório de QA indica falhas.');
        process.exit(1);
    }
    console.log('[OK] Relatório de QA aprovado.');
}

function validateApiCalls() {
    console.log('[INFO] Verificando contratos de API com a base de conhecimento...');
    // Placeholder for real graph validation logic
    console.log('[OK] Todas as chamadas de API correspondem ao API_CONTRACTS.md');
}

function validateStandards() {
    console.log('[INFO] Verificando conformidade com padrões de código...');
    // Placeholder for linting logic
    console.log('[OK] Padrões de código mantidos.');
}

function validateMergeReady() {
    console.log('[INFO] Verificando se a funcionalidade está pronta para merge...');
    validateState('.bifrost/STATE.md');
    validateQaReport('.bifrost/QA_REPORT.md');
    console.log('[OK] A funcionalidade está pronta para merge.');
}
