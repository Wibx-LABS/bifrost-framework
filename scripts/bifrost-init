#!/usr/bin/env node

/**
 * Bifrost Initialization Script (Interactive Selector Version)
 * Transforms a folder into a Bifrost feature project
 */

const fs = require('fs');
const path = require('path');
const readline = require('readline');
const { execSync } = require('child_process');

// UI Helpers
const colors = {
    reset: "\x1b[0m",
    bright: "\x1b[1m",
    dim: "\x1b[2m",
    fg: {
        black: "\x1b[30m",
        red: "\x1b[31m",
        green: "\x1b[32m",
        yellow: "\x1b[33m",
        blue: "\x1b[34m",
        magenta: "\x1b[35m",
        cyan: "\x1b[36m",
        white: "\x1b[37m",
    }
};

const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout
});

const REPO_ROOT = path.resolve(__dirname, '..');

async function ask(question) {
    return new Promise((resolve) => {
        rl.question(`${colors.fg.cyan}? ${colors.reset}${question}`, (answer) => {
            resolve(answer);
        });
    });
}

/**
 * Interactive Selector
 * Allows user to choose from a list of options using numbers
 */
async function select(question, options) {
    console.log(`\n${colors.fg.cyan}? ${colors.reset}${colors.bright}${question}${colors.reset}`);
    options.forEach((opt, idx) => {
        console.log(`  ${colors.fg.cyan}${idx + 1})${colors.reset} ${opt}`);
    });
    
    while (true) {
        const answer = await ask(`Escolha uma opção (1-${options.length}): `);
        const idx = parseInt(answer) - 1;
        if (idx >= 0 && idx < options.length) {
            return options[idx];
        }
        console.log(`${colors.fg.red}Escolha inválida. Por favor, escolha um número entre 1 e ${options.length}.${colors.reset}`);
    }
}

async function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

async function withSpinner(message, action) {
    const chars = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
    let i = 0;
    const interval = setInterval(() => {
        process.stdout.write(`\r${colors.fg.yellow}${chars[i++ % chars.length]}${colors.reset} ${message}`);
    }, 80);
    
    try {
        const result = await action();
        clearInterval(interval);
        process.stdout.write(`\r${colors.fg.green}[OK]${colors.reset} ${message}\n`);
        return result;
    } catch (e) {
        clearInterval(interval);
        process.stdout.write(`\r${colors.fg.red}[ERRO]${colors.reset} ${message}\n`);
        throw e;
    }
}

async function main() {
    console.clear();
    console.log(`
${colors.fg.cyan}${colors.bright}██████╗ ██╗███████╗██████╗  ██████╗ ███████╗████████╗
██╔══██╗██║██╔════╝██╔══██╗██╔═══██╗██╔════╝╚══██╔══╝
██████╔╝██║█████╗  ██████╔╝██║   ██║███████╗   ██║   
██╔══██╗██║██╔══╝  ██╔══██╗██║   ██║╚════██║   ██║   
██████╔╝██║██║     ██║  ██║╚██████╔╝███████║   ██║   
╚═════╝ ╚═╝╚═╝     ╚═╝  ╚═╝ ╚═════╝ ╚══════╝   ╚═╝   ${colors.reset}

${colors.dim}> WibX Labs | Advanced Agentic Coding Framework${colors.reset}
`);

    await withSpinner('Verificando requisitos do sistema...', async () => {
        await sleep(600);
        execSync('git --version');
    });

    console.log(`\n${colors.fg.green}[OK] Sistema Pronto.${colors.reset}\n`);

    if (fs.existsSync('.bifrost')) {
        const overwrite = await ask(`${colors.fg.yellow}Aviso: A pasta .bifrost já existe. Sobrescrever? (y/N) ${colors.reset}`);
        if (overwrite.toLowerCase() !== 'y') {
            console.log('\n[!] Inicialização cancelada.');
            process.exit(0);
        }
    }

    const pathChoice = await select('QUAL É O DESTINO DESTE TRABALHO?', [
        'Superfície WiBOO Existente (Dashboard, App, etc.)',
        'Novo Projeto Independente (Do Zero)',
        'Landing Page / Uso Único (Fast-Track)'
    ]);
    
    let projectDetails = {
        name: '',
        targetApp: '',
        scope: '',
        actions: []
    };

    if (pathChoice.includes('Superfície WiBOO Existente')) {
        projectDetails.targetApp = await select('Qual aplicação estamos focando?', [
            'Plataforma Merchant (Negócios)',
            'Perfil de Usuário e Segurança (Conta)',
            'Compras e Produtos (Shopping)',
            'Jogo WiBX Go (Gamificação)'
        ]);
        
        projectDetails.scope = await select('Qual é o escopo?', [
            'Nova Seção/Página',
            'Atualizar Seção Existente',
            'Ferramenta Reutilizável'
        ]);
        
        projectDetails.name = await ask('Nome da funcionalidade (ex: "Notificações do Usuário"): ');
    } else if (pathChoice.includes('Novo Projeto Independente')) {
        projectDetails.name = await ask('Qual é o nome deste projeto? ');
        console.log(`\n${colors.dim}Liste as 3 ações mais importantes do usuário:${colors.reset}`);
        projectDetails.actions.push(await ask('Ação 1: '));
        projectDetails.actions.push(await ask('Ação 2: '));
        projectDetails.actions.push(await ask('Ação 3: '));
    } else {
        projectDetails.name = await ask('O que estamos construindo? (ex: "Protótipo de Ferramenta Interna"): ');
    }

    console.log(`\n${colors.bright}┌─ INICIALIZANDO PROJETO ─────────────────────────────┐${colors.reset}`);
    
    await withSpinner('Criando estrutura .bifrost...', async () => {
        await sleep(500);
        if (!fs.existsSync('.bifrost')) fs.mkdirSync('.bifrost', { recursive: true });
        if (!fs.existsSync('.bifrost/agents')) fs.mkdirSync('.bifrost/agents', { recursive: true });
        if (!fs.existsSync('.bifrost/skills')) fs.mkdirSync('.bifrost/skills', { recursive: true });
    });

    await withSpinner('Hidratando templates de agentes...', async () => {
        await sleep(700);
        const templateDir = path.join(REPO_ROOT, 'core/templates');
        if (fs.existsSync(templateDir)) {
            const templates = fs.readdirSync(templateDir);
            templates.forEach(file => {
                if (fs.lstatSync(path.join(templateDir, file)).isFile()) {
                    let content = fs.readFileSync(path.join(templateDir, file), 'utf8');
                    content = content.replace(/{{PROJECT_NAME}}/g, projectDetails.name);
                    content = content.replace(/{{TARGET_APP}}/g, projectDetails.targetApp || 'N/A');
                    content = content.replace(/{{STATUS}}/g, 'initialized');
                    content = content.replace(/{{CREATED}}/g, new Date().toISOString());
                    content = content.replace(/{{VERSION}}/g, '1.0.0');
                    content = content.replace(/{{ID}}/g, Math.random().toString(36).substring(2, 11));
                    
                    fs.writeFileSync(path.join('.bifrost', file), content);
                }
            });
        }
    });

    await withSpinner('Instalando Git Hooks...', async () => {
        await sleep(500);
        const hookDir = path.join(REPO_ROOT, 'runtime/hooks');
        const targetHookDir = '.git/hooks';
        if (fs.existsSync('.git') && fs.existsSync(hookDir)) {
            if (!fs.existsSync(targetHookDir)) fs.mkdirSync(targetHookDir, { recursive: true });
            
            fs.copyFileSync(path.join(hookDir, 'pre-commit.sh'), path.join(targetHookDir, 'pre-commit'));
            fs.copyFileSync(path.join(hookDir, 'post-merge.sh'), path.join(targetHookDir, 'post-merge'));
            
            try {
                execSync(`chmod +x ${targetHookDir}/pre-commit ${targetHookDir}/post-merge`);
            } catch (e) {}
        }
    });

    console.log(`${colors.bright}└─────────────────────────────────────────────────────┘${colors.reset}`);

    console.log(`
${colors.fg.green}${colors.bright}┌─────────────────────────────────────────────────────┐
│                                                     │
│  [OK] CONFIGURAÇÃO CONCLUÍDA                        │
│                                                     │
│  Área de Trabalho: .bifrost/                        │
│  Funcionalidade:   ${projectDetails.name.substring(0, 36).padEnd(36)} │
│                                                     │
│  PRÓXIMOS PASSOS:                                   │
│  1. Edite .bifrost/PATIENT.md com o escopo          │
│  2. No Antigravity, execute /bifrost:start          │
│                                                     │
└─────────────────────────────────────────────────────┘${colors.reset}
`);

    rl.close();
}

main().catch(err => {
    console.error(`\n${colors.fg.red}[ERRO] Erro durante a inicialização:${colors.reset}`);
    console.error(err);
    process.exit(1);
});
