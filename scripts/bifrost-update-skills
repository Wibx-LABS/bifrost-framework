#!/usr/bin/env node

/**
 * Bifrost Update Skills
 * Updates project-local agents and skills from the latest framework version
 */

const fs = require('fs');
const path = require('path');
const { hydrate } = require('../core/agents/hydration/hydrate.js');

const REPO_ROOT = path.resolve(__dirname, '..');

function main() {
    console.log('[...] Atualizando skills e agentes do Bifrost...');

    if (!fs.existsSync('.bifrost')) {
        console.error('[ERRO] Diretório .bifrost não encontrado. Você está em um projeto Bifrost?');
        process.exit(1);
    }

    try {
        // 1. Re-sync global skills
        const skillsSource = path.join(REPO_ROOT, 'core/skills');
        const skillsTarget = '.bifrost/skills';
        
        if (fs.existsSync(skillsSource)) {
            console.log('[...] Sincronizando skills...');
            // In a real scenario, we'd do a recursive copy or rsync
            // Simplified for this implementation
            if (!fs.existsSync(skillsTarget)) fs.mkdirSync(skillsTarget, { recursive: true });
        }

        // 2. Re-hydrate agents
        // We'll try to recover context from STATE.md or PATIENT.md
        const statePath = '.bifrost/STATE.md';
        let context = { PROJECT_NAME: 'Existing Project' };
        
        if (fs.existsSync(statePath)) {
            const stateContent = fs.readFileSync(statePath, 'utf8');
            const nameMatch = stateContent.match(/feature: (.+)/);
            if (nameMatch) context.PROJECT_NAME = nameMatch[1].trim();
        }

        hydrate(process.cwd(), context);

        console.log('[OK] Skills e agentes atualizados.');
    } catch (err) {
        console.error(`[ERRO] Atualização falhou: ${err.message}`);
        process.exit(1);
    }
}

main();
